{
  "name": "gif-recorder",
  "version": "1.0.0",
  "description": "Automated GIF recorder for VS Code extension demos using Playwright",
  "private": true,
  "scripts": {
    "build": "tsc",
    "record": "ts-node src/runner.ts",
    "record:runbook": "ts-node src/runner.ts specs/runbook.yaml",
    "record:json-preview": "ts-node src/runner.ts specs/json-preview.yaml",
    "record:base": "ts-node src/runner.ts specs/base.yaml",
    "record:bookmark": "ts-node src/runner.ts specs/bookmark.yaml",
    "record:workflow": "ts-node src/runner.ts specs/workflow.yaml",
    "test:scale": "ts-node src/test-scale.ts"
  },
  "dependencies": {
    "@vscode/test-electron": "^2.4.0",
    "js-yaml": "^4.1.0",
    "playwright": "^1.44.0",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/sharp": "^0.31.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
